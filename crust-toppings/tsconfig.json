{
  "compilerOptions": {
    "target":            "ES2022",
    "lib":               ["ES2022", "DOM", "DOM.Iterable"],
    "module":            "ESNext",
    "moduleResolution":  "Bundler",
    "jsx":               "react-jsx",
    "strict":            true,
    "noEmit":            true,
    "skipLibCheck":      true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules":   true,
    "types":             ["jest", "@testing-library/jest-dom"]
  },
  "include": ["src", "vite.config.ts"]
}
