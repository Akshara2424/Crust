{
  "compilerOptions": {
    "target":            "ES2022",
    "lib":               ["ES2022"],
    "module":            "CommonJS",
    "moduleResolution":  "Node",
    "outDir":            "dist",
    "rootDir":           "server",
    "strict":            true,
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "resolveJsonModule": true,
    "sourceMap":         true
  },
  "include":  ["server"],
  "exclude":  ["node_modules", "dist", "frontend"]
}
