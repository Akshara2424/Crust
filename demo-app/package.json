{
  "name": "crust-demo-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":         "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server":  "ts-node-dev --respawn --transpile-only server/index.ts",
    "dev:frontend":"vite",
    "build":       "tsc -p tsconfig.server.json && vite build",
    "start":       "node dist/server/index.js"
  },
  "dependencies": {
    "cors":                  "^2.8.5",
    "crust-middleware":      "file:../crust-middleware",
    "dotenv":                "^16.4.5",
    "express":               "^4.19.2",
    "http-proxy-middleware": "^3.0.2",
    "framer-motion":         "^11.0.0",
    "react":                 "^18.2.0",
    "react-dom":             "^18.2.0"
  },
  "devDependencies": {
    "@types/cors":           "^2.8.17",
    "@types/express":        "^4.17.21",
    "@types/node":           "^20.0.0",
    "@types/react":          "^18.2.0",
    "@types/react-dom":      "^18.2.0",
    "@vitejs/plugin-react":  "^4.2.0",
    "concurrently":          "^8.2.0",
    "ts-node-dev":           "^2.0.0",
    "typescript":            "^5.3.0",
    "vite":                  "^5.0.0"
  }
}
