{
  "compilerOptions": {
    "target":                       "ES2022",
    "module":                       "commonjs",
    "lib":                          ["ES2022"],
    "moduleResolution":             "node",
    "strict":                       true,
    "esModuleInterop":              true,
    "skipLibCheck":                 true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule":            true,
    "declaration":                  true,
    "outDir":                       "./dist",
    "rootDir":                      "./server"
  },
  "include": ["server/**/*"],
  "exclude": ["node_modules"]
}
