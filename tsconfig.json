{
  "compilerOptions": {
    // ── Output ──────────────────────────────────────────────────────────────
    "target":    "ES2020",
    "module":    "ES2020",
    "moduleResolution": "bundler",
    "outDir":    "./dist",
    "rootDir":   ".",

    // ── Type declarations ────────────────────────────────────────────────────
    "declaration":    true,
    "declarationMap": true,
    "sourceMap":      true,

    // ── Libraries ────────────────────────────────────────────────────────────
    // DOM + WebWorker both required: index.ts targets DOM, worker.ts targets
    // WebWorker.  They share the same tsconfig so both lib sets are included.
    "lib": ["ES2020", "DOM", "DOM.Iterable", "WebWorker"],

    // ── Strict mode — all flags on ───────────────────────────────────────────
    "strict":                        true,
    "skipLibCheck":                  true,
    "noUncheckedIndexedAccess":      true,
    "noImplicitOverride":            true,
    "noPropertyAccessFromIndexSignature": true,
    "useUnknownInCatchVariables":    true,
    "forceConsistentCasingInFileNames": true,

    // ── Interop ───────────────────────────────────────────────────────────────
    "esModuleInterop":            true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule":          true,
    "isolatedModules":            true
  },
  "include": ["*.ts", "crust-SDK/src/index.ts", "crust-SDK/src/worker.ts", "crust-SDK/src/toppings-stub.ts", "crust-SDK/src/types.ts", "crust-SDK/src/features/mouse.ts", "crust-SDK/src/features/environment.ts", "crust-SDK/src/features/keystroke.ts", "crust-SDK/src/features/session.ts", "crust-SDK/src/features/network.ts"],
  "exclude": ["node_modules", "dist"]
}
