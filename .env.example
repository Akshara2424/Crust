# ══════════════════════════════════════════════════════════════════════════════
# CRUST — Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── RSA Key Pair (RS256, 2048-bit) ─────────────────────────────────────────────
#
# Generate with:
#   openssl genrsa -out crust_private.pem 2048
#   openssl rsa -in crust_private.pem -pubout -out crust_public.pem
#
# Then base64-encode for env vars:
#   export CRUST_PRIVATE_KEY_PEM=$(base64 -w 0 crust_private.pem)
#   export CRUST_PUBLIC_KEY_PEM=$(base64 -w 0 crust_public.pem)
#
# The Python service will base64-decode before use.
# The Express middleware expects the raw PEM string (already decoded).

CRUST_PRIVATE_KEY_PEM=<base64-encoded RSA private key PEM>
CRUST_PUBLIC_KEY_PEM=<base64-encoded RSA public key PEM>

# ── Service URLs ───────────────────────────────────────────────────────────────

# URL the demo-app server uses to proxy requests to the Python ML service
# In Docker Compose this is the service name: http://crust-service:8000
# For local dev without Docker: http://localhost:8000
CRUST_SERVICE_URL=http://crust-service:8000

# ── Demo App ───────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development

# ── Python Service ─────────────────────────────────────────────────────────────

# Path inside the container where the XGBoost model JSON is mounted
CRUST_MODEL_PATH=/app/model/crust_model.json

# Log level for uvicorn / FastAPI (debug | info | warning | error)
LOG_LEVEL=info
